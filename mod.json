{
    "geode": "5.3.0",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },

    "version": "v1.0.0",
    "id": "undefined0.custom-transitions",
    "name": "Custom Transitions",
    "developer": "undefined0",
    "description": "Use any image for a custom fade transition!",
    "tags": [ "customization", "enhancement", "interface" ],

    "links": {
        "source": "https://github.com/undefined06855/Custom-Transitions"
    },

    "resources": {
        "files": [ "resources/*.png" ]
    },

    "settings": {
        "image-path": {
            "type": "file",
            "name": "Image",
            "default": "{mod_config_dir}/wibblywobbly.png",
            "control": {
                "dialog": "open",
                "filters": [{
                    "files": [ "*.png", "*.jpg", "*.tiff" ]
                }]
            }
        },
        "duration": {
            "type": "float",
            "name": "Duration",
            "default": 0.6,
            "min": 0,
            "max": 2,
            "control": {
                "arrows": false,
                "slider": true,
                "input": true
            }
        },
        "edge-size": {
            "type": "float",
            "name": "Edge size",
            "description": "The percentage of time that is spent fading between solid and transparent.\n\n0 means each pixel will snap as soon as the threshold is reached, 0.5 means each pixel will take half the time to go between invisible and solid once the threshold is reached.",
            "default": 0.25,
            "min": 0.0,
            "max": 1.0,
            "control": {
                "arrows": false,
                "slider": true,
                "slider-step": 0.05,
                "input": true
            }
        },
        "reload-songs": {
            "name": "Open built-in transitions folder",
            "type": "custom:reload-song-button"
        }
    }
}
